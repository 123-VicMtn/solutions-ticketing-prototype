<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
</head>
<body style="font-family: system-ui, sans-serif; line-height: 1.5; color: #111;">
  <h1>Nouvelle demande d’accès</h1>
  <p>
    <strong>{{ applicantName }}</strong> ({{ applicantEmail }}) demande un accès en tant que
    <strong>{{ applicantRole }}</strong>.
  </p>
  <p>
    <a href="{{ managerUrl }}" style="display: inline-block; padding: 10px 16px; background: #111; color: #fff; text-decoration: none; border-radius: 6px;">
      Traiter les demandes
    </a>
  </p>
  <p style="font-size: 12px; color: #666;">{{ brandName }}</p>
</body>
</html>
