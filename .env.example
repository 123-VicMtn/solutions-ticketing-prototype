# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333

# Mail — voir docs/MAIL.md
#
# Vrais emails (Internet) : SMTP du fournisseur + identifiants + MAIL_FROM autorisé
# MAIL_MAILER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@ton-domaine.ch
# APP_URL=https://ton-domaine.ch
#
# Local sans envoi réel (Mailpit) :
MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=noreply@localhost.test
MAIL_FROM_NAME=123 Ticketing
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# SMTP_SECURE=true

# Debug : aucun envoi, JSON dans les logs du terminal
# MAIL_MAILER=log

# Database
DB_HOST=postgres
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_DATABASE=
# Connection pool (optionnel)
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# SSL DB (recommandé si DB externe)
# DB_USE_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Session
SESSION_DRIVER=cookie
LIMITER_STORE=database

# Attachments storage
ATTACHMENTS_DRIVER=local
ATTACHMENTS_LOCAL_TICKETS_DIR=uploads/tickets
ATTACHMENTS_LOCAL_PUBLIC_BASE_PATH=/uploads/tickets

# S3-compatible settings (provider-agnostic)
# Exoscale bootstrap example:
# ATTACHMENTS_S3_ENDPOINT=
# ATTACHMENTS_S3_REGION=
# ATTACHMENTS_S3_BUCKET=
# ATTACHMENTS_S3_ACCESS_KEY_ID=
# ATTACHMENTS_S3_SECRET_ACCESS_KEY=
# ATTACHMENTS_S3_FORCE_PATH_STYLE=false
# ATTACHMENTS_S3_KEY_PREFIX=tickets
# ATTACHMENTS_S3_SIGNED_URL_TTL_SECONDS=300

# Monitoring healthcheck 
# HEALTH_CHECK_SECRET=