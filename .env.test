TZ=Europe/Paris
NODE_ENV=test
HOST=127.0.0.1
PORT=3333

LOG_LEVEL=error

# Test-only app key (non secret)
APP_KEY=test_test_test_test_test_test_test_test
APP_URL=http://127.0.0.1:3333

# Mail: no real SMTP in test
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.test
MAIL_FROM_NAME=123 Ticketing (test)

# Database: when running tests from IDE, use the published Postgres port
# (Docker Compose exposes it on localhost:5432 by default)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ticketing
DB_PASSWORD=ticketing
DB_DATABASE=ticketing_test

# Session / limiter
SESSION_DRIVER=memory
LIMITER_STORE=memory

# Attachments: never use real S3 credentials in tests
ATTACHMENTS_DRIVER=local
ATTACHMENTS_LOCAL_TICKETS_DIR=uploads/tickets
ATTACHMENTS_LOCAL_PUBLIC_BASE_PATH=/uploads/tickets
